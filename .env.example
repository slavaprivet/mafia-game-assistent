# ══════════════════════════════════════════════════════
#  Настройки бота-помощника по разработке игры
#  Скопируй этот файл в .env и заполни свои значения
# ══════════════════════════════════════════════════════

# ── Telegram ─────────────────────────────────────────
# Токен бота — получи у @BotFather в Telegram
BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Твой Telegram user_id (узнать: написать @userinfobot)
# Несколько ID через запятую: 123456,789012
ALLOWED_USERS=123456789

# ── Ollama (локальный AI) ─────────────────────────────
# Адрес сервера Ollama (по умолчанию localhost:11434)
OLLAMA_URL=http://localhost:11434

# Модель для анализа кода (установить: ollama pull qwen2.5-coder:7b)
CODE_MODEL=qwen2.5-coder:7b

# Модель для анализа изображений (установить: ollama pull llava)
VISION_MODEL=llava

# ── Пути ─────────────────────────────────────────────
# Папка с кодом твоей игры (абсолютный путь или относительный от бота)
# По умолчанию: папка game_repo/ рядом с ботом
GAME_REPO_PATH=game_repo

# ── Лимиты ───────────────────────────────────────────
# Максимум токенов в день (0 = без лимита)
DAILY_TOKEN_LIMIT=5000000

# Максимальный размер контекста кода для AI (в символах)
MAX_CONTEXT_SIZE=50000

# Количество последних сообщений в памяти разговора
CONVERSATION_HISTORY_SIZE=20

# ── Прочее ───────────────────────────────────────────
# Ежечасные отчёты об использовании токенов (true/false)
HOURLY_REPORTS=false
